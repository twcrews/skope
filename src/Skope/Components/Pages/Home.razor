@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject UserService UserService
@using Microsoft.EntityFrameworkCore
@implements IDisposable

<AuthorizeView>
    <NotAuthorized>
        <LandingView />
    </NotAuthorized>
    <Authorized Context="authContext">
        <PageTitle>Skope — Dashboards</PageTitle>
        <MudStack Style="min-height: calc(100vh - 80px);">
            <MudStack Style="flex: 1;">
                <MudStack Row AlignItems="AlignItems.Center" Class="mb-5">
                    <MudText Typo="Typo.h4">Your Dashboards</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenNewDashboardDialogAsync">
                        New Dashboard
                    </MudButton>
                </MudStack>

                @if (_dashboards is null)
                {
                    <div class="d-flex justify-center pa-8">
                        <MudProgressCircular Indeterminate />
                    </div>
                }
                else if (_dashboards.Count == 0)
                {
                    <MudPaper Elevation="0" Class="d-flex flex-column align-center pa-12"
                              Style="border: 1px dashed var(--mud-palette-divider);">
                        <MudIcon Icon="@Icons.Material.Outlined.Dashboard"
                                 Size="Size.Large" Class="mb-4" />
                        <MudText Typo="Typo.h6" Class="mb-2">No dashboards yet</MudText>
                        <MudText Typo="Typo.body2">
                            Create your first dashboard to start exploring your Planning Center data.
                        </MudText>
                    </MudPaper>
                }
                else
                {
                    <MudGrid Spacing="3">
                        @foreach (var dashboard in _dashboards)
                        {
                            <MudItem xs="12" sm="6" lg="4">
                                <MudPaper Elevation="0" Outlined Class="pa-5 cursor-pointer mud-ripple"
                                          @onclick="@(() => Nav.NavigateTo($"/{UserService.CurrentOrganization?.ChurchCenterSubdomain}/{dashboard.Slug}"))">
                                    <MudStack Row AlignItems="AlignItems.Center" Class="mb-1">
                                        <MudText Typo="Typo.h6">@dashboard.Title</MudText>
                                        <MudSpacer />
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(dashboard.IsPublic ? Color.Success : Color.Default)"
                                                 Variant="Variant.Text">
                                            @(dashboard.IsPublic ? "Public" : "Private")
                                        </MudChip>
                                    </MudStack>
                                    <MudText Typo="Typo.body2" Class="mb-4" Style="opacity:0.45;">
                                        /@(UserService.CurrentOrganization?.ChurchCenterSubdomain + "/" + dashboard.Slug)
                                    </MudText>
                                    <MudStack Row AlignItems="AlignItems.Center">
                                        <MudIcon Icon="@Icons.Material.Outlined.Widgets"
                                                 Size="Size.Small" Style="opacity:0.4;" />
                                        <MudText Typo="Typo.caption" Style="opacity:0.6;">
                                            @dashboard.Widgets.Count @(dashboard.Widgets.Count == 1 ? "widget" : "widgets")
                                        </MudText>
                                        <MudSpacer />
                                        <MudText Typo="Typo.caption" Style="opacity:0.4;">
                                            Updated @dashboard.UpdatedAt.ToString("MMM d")
                                        </MudText>
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                }
            </MudStack>

            <MudPaper Elevation="0" Outlined Class="pa-6 mt-8">
                <MudText Typo="Typo.h4" GutterBottom="true">Discover</MudText>
                <MudText Typo="Typo.body2" Class="mb-6" Style="opacity: 0.6;">
                    Dashboards created by others in your organization
                </MudText>
                <MudDivider Class="mb-6" />
                <MudText Typo="Typo.body2">
                    <b>Nothing here yet!</b> Public and shared dashboards from your organization will appear here.
                </MudText>
            </MudPaper>
        </MudStack>
    </Authorized>
</AuthorizeView>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private int _currentUserId;
    private List<Dashboard>? _dashboards;

    protected override async Task OnInitializedAsync()
    {
        UserService.CurrentUserChanged += OnCurrentUserChanged;
        var state = await AuthenticationStateTask;
        var sub = state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        await using var db = await DbFactory.CreateDbContextAsync();
        var user = await db.Users.FirstOrDefaultAsync(u => u.PlanningCenterId == sub);
        _currentUserId = user?.Id ?? 0;
        await LoadDashboardsAsync(db);
    }

    private async Task LoadDashboardsAsync(AppDbContext? db = null)
    {
        if (db is null)
        {
            await using var ownedDb = await DbFactory.CreateDbContextAsync();
            await LoadDashboardsAsync(ownedDb);
            return;
        }
        _dashboards = await db.Dashboards
            .Where(d => d.OwnerId == _currentUserId)
            .Include(d => d.Widgets)
            .OrderByDescending(d => d.UpdatedAt)
            .ToListAsync();
    }

    private async Task OpenNewDashboardDialogAsync()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<NewDashboardDialog>("New Dashboard", options);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: NewDashboardDialog.DashboardInit init })
            await CreateDashboardAsync(init);
    }

    private void OnCurrentUserChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);

    public void Dispose() => UserService.CurrentUserChanged -= OnCurrentUserChanged;

    private async Task CreateDashboardAsync(NewDashboardDialog.DashboardInit init)
    {
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            db.Dashboards.Add(new Dashboard
            {
                OwnerId = _currentUserId,
                UpdatedById = _currentUserId,
                Title = init.Title,
                Slug = init.Slug,
                Description = init.Description,
                IsPublic = init.IsPublic,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow,
            });
            await db.SaveChangesAsync();
            await LoadDashboardsAsync();
        }
        catch (DbUpdateException ex)
            when (ex.InnerException is Microsoft.Data.SqlClient.SqlException { Number: 2601 or 2627 })
        {
            Snackbar.Add($"A dashboard with path \"{init.Slug}\" already exists.", Severity.Error);
        }
    }
}
