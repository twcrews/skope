@page "/"
@inject MockAuthService AuthState
@implements IDisposable

@if (!AuthState.IsAuthenticated)
{
    <LandingView OnSignIn="SignIn" />
}
else
{
    <PageTitle>Skope — Dashboards</PageTitle>
    <div style="display: flex; flex-direction: column; min-height: calc(100vh - 80px);">
        <div style="flex: 1;">
            <MudText Typo="Typo.h4"  GutterBottom="true">Your Dashboards</MudText>
            <MudPaper Elevation="0" Class="d-flex flex-column align-center pa-12"
                      Style="border: 1px dashed var(--mud-palette-divider);">
                <MudIcon Icon="@Icons.Material.Outlined.Dashboard"
                         Size="Size.Large" Class="mb-4" />
                <MudText Typo="Typo.h6" Class="mb-2">No dashboards yet</MudText>
                <MudText Typo="Typo.body2" Class="mb-6">
                    Create your first dashboard to start exploring your Planning Center data.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add">
                    Create Dashboard
                </MudButton>
            </MudPaper>
        </div>

        <MudPaper Elevation="0" Outlined Class="pa-6 mt-8">
            <MudText Typo="Typo.h4" GutterBottom="true">Discover</MudText>
            <MudText Typo="Typo.body2" Class="mb-6" Style="opacity: 0.6;">
                Dashboards created by others in your organization
            </MudText>
            <MudDivider Class="mb-6" />
            <MudText Typo="Typo.body2">
                <b>Nothing here yet!</b> Public and shared dashboards from your organization will appear here.
            </MudText>
        </MudPaper>
    </div>
}

@code {
    private Action? _authChangeHandler;

    protected override void OnInitialized()
    {
        _authChangeHandler = () => InvokeAsync(StateHasChanged);
        AuthState.OnChange += _authChangeHandler;
    }

    private void SignIn() => AuthState.SignIn();

    public void Dispose() => AuthState.OnChange -= _authChangeHandler;
}
