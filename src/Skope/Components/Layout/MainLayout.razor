@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudLayout>
    <MudAppBar Elevation="0" Dense Style="border-bottom:1px solid var(--mud-palette-divider);">
        <MudImage Src="@(_isDarkMode ? "wordmark-light.svg" : "wordmark.svg")" Alt="Skope" Height="32" />
        <MudSpacer />
        <MudIconButton Icon="@(DarkLightModeButtonIcon)" Color="Color.Inherit" OnClick="@DarkModeToggle" />
        <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" Edge="Edge.End" />
    </MudAppBar>
    <MudDrawer id="nav-drawer" @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0"
               Variant="DrawerVariant.Mini" Style="border-right:1px solid var(--mud-palette-divider);">
        <NavMenu DrawerOpen="_drawerOpen" OnToggleDrawer="DrawerToggle" />
    </MudDrawer>
    <MudMainContent Class="pt-16 pa-4">
        @Body
    </MudMainContent>
</MudLayout>


<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen;
    private bool _isDarkMode = true;
    private MudTheme? _theme = null;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties(),
            Typography = new Typography()
            {
                Default = new DefaultTypography()
                {
                    FontFamily = new[] { "Inter", "sans-serif" }
                }
            }
        };
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
    }

    private readonly PaletteLight _lightPalette = new()
    {
        Primary = BrandColors.Blue600,
        Secondary = BrandColors.Teal400,
        Tertiary = BrandColors.Amber200,
        Black = BrandColors.Gray900,
        Background = BrandColors.Gray50,
        Surface = BrandColors.White,
        AppbarBackground = BrandColors.White,
        AppbarText = BrandColors.Blue600,
        DrawerBackground = BrandColors.White,
        DrawerText = BrandColors.Gray800,
        DrawerIcon = BrandColors.Gray400,
        TextPrimary = BrandColors.Gray800,
        TextSecondary = BrandColors.Gray400,
        LinesDefault = BrandColors.Gray100,
        TableLines = BrandColors.Gray100,
        Divider = BrandColors.Gray100,
        GrayLight = BrandColors.Gray100,
        GrayLighter = BrandColors.Gray50,
        Info = BrandColors.Blue400,
        Success = BrandColors.Teal400,
        Warning = BrandColors.Amber200,
        Error = BrandColors.ErrorLight,
    };

    private readonly PaletteDark _darkPalette = new()
    {
        Primary = BrandColors.Blue400,
        Secondary = BrandColors.Teal400,
        Tertiary = BrandColors.Amber200,
        Background = BrandColors.DarkBackground,
        Surface = BrandColors.DarkSurface,
        BackgroundGray = BrandColors.DarkNavBackground,
        AppbarBackground = BrandColors.DarkNavBackground,
        AppbarText = BrandColors.Blue100,
        DrawerBackground = BrandColors.DarkNavBackground,
        DrawerText = BrandColors.Blue200,
        DrawerIcon = BrandColors.Blue200,
        ActionDefault = BrandColors.Blue100,
        ActionDisabled = BrandColors.Blue100Alpha30,
        ActionDisabledBackground = BrandColors.DarkBorderAlpha30,
        TextPrimary = BrandColors.DarkBodyText,
        TextSecondary = BrandColors.Blue100,
        TextDisabled = BrandColors.DarkBodyTextAlpha20,
        LinesDefault = BrandColors.DarkBorder,
        TableLines = BrandColors.DarkBorder,
        Divider = BrandColors.DarkBorder,
        GrayLight = BrandColors.DarkBorder,
        GrayLighter = BrandColors.DarkSurface,
        Info = BrandColors.Blue400,
        Success = BrandColors.Teal400,
        Warning = BrandColors.Amber200,
        Error = BrandColors.ErrorDark,
        OverlayLight = BrandColors.DarkBackgroundAlpha50,
    };

    public string DarkLightModeButtonIcon => _isDarkMode switch
    {
        true => Icons.Material.Rounded.AutoMode,
        false => Icons.Material.Outlined.DarkMode,
    };
}


